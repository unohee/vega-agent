# VEGA Agent — environment variables
# Copy this file to .env and fill in your values. Never commit .env.

# ── LLM Providers ──────────────────────────────────────────────
# OpenRouter (recommended for multi-model support)
# NOTE: 변수명은 OPENROUTER_API (data/llm_providers.json 의 api_key_env 와 일치해야 함)
OPENROUTER_API=

# OpenAI-compatible (LM Studio, Ollama, etc.)
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=local

# ── Search ─────────────────────────────────────────────────────
# SearXNG endpoint (self-hosted recommended, or public endpoint with API key)
VEGA_SEARXNG_URL=http://localhost:18888
# API key for public SearXNG endpoint (X-VEGA-Key header); leave empty for local
VEGA_API_KEY=

# ── Google OAuth ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Channel adapters (optional) ────────────────────────────────
# Telegram bot — token from @BotFather
TELEGRAM_BOT_TOKEN=
# Slack bot (Socket Mode) — xoxb bot token + xapp app-level token
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Discord (disabled in vega-agent; stubbed) ───────────────────
# DISCORD_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=

# ── Enterprise access (optional) ───────────────────────────────
# Comma-separated keys for X-VEGA-Key header authentication
# VEGA_ENTERPRISE_KEYS=key1,key2
