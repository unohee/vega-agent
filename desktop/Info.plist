<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Tauri v2 macOS 번들러가 생성하는 Info.plist 에 병합된다(같은 디렉터리의 Info.plist).
     마이크 사용 설명이 없으면 WKWebView 가 navigator.mediaDevices 를 노출하지 않아
     마이크 버튼이 "마이크 미지원"으로 뜬다(INT-2000). audio-input entitlement 와 함께 필요. -->
<plist version="1.0">
<dict>
    <key>NSMicrophoneUsageDescription</key>
    <string>VEGA가 음성 입력(STT)·회의 녹취를 위해 마이크를 사용합니다.</string>
</dict>
</plist>
