{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VEGA",
  "version": "0.1.2",
  "identifier": "com.unohee.vega",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "externalBin": ["../bin/vega-backend"],
    "resources": {
      "dist/*": "./",
      "resources/*": "./"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Heewon Oh (635QK74RYK)",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    }
  }
}
