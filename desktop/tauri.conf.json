{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VEGA",
  "version": "0.1.44",
  "identifier": "com.unohee.vega",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGMkQxNzQxOEQ2MUVFN0MKUldSODdtR05RUmN0LzlrNyt4cjhBV1lTYllPcVQ1bmZXcUk0eTY1YTViVDA0eEwvUGgwcnNvS1EK",
